{% include 'incl/header.twig' %}

<body>
    {% include 'incl/nav.twig' %}

    <div class="main" role="main">
        <div class="subpage">
            <aside class="sidebar">
                <ul>
                    {% for page in pages("analysis/sub") if not page.hidden %}
                    <li>
                        <a href="{{ page.url }}">{{ page.title }}</a>
                    </li>
                    {% endfor %}
                </ul>
            </aside>

            <div class="content">
                <a class="return" href="{{ base_url }}/analysis" title="Return to landingpage">
                    <i class="fas fa-arrow-left" aria-hidden="true"></i>
                    <span class="sr-only">Return</span>
                </a>
                <article class="article">
                    {{ content }}
                </article>
            </div>
        </div>
    </div>
    
    {% include 'incl/footer.twig' %}
</body>

</html>
