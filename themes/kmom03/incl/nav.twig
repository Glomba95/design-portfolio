<div class="header" role="banner">
    <div class="site-header">
        <div class="title" {{ pages["_meta"].meta.tagline ? ' class="tagline"' }}>
            <a href="{{ base_url }}">
                <h1>
                    <span class="title-row-1">Ebba</span>
                    <span class="title-row-2">Amnehagen</span>
                </h1>
                {# <h2>{{ pages["_meta"].meta.tagline|markdown }}</h2> #}
            </a>
        </div>

        <a class="nav-toggle" id="nav-toggle" title="Toggle Menu" role="button" aria-controls="nav"
            aria-expanded="false" tabindex="1">
            <i class="fa fa-bars" aria-hidden="true" id="toggler"></i>
            <span class="sr-only">Toggle Menu</span>
        </a>
    </div>

    <div class="nav">
        <div id="nav" role="navigation" tabindex="-1">
            <ul>
                {% set navIcons = pages._meta.meta.Nav %}
                {% for page in pages(depthOffset=-1) if page.title and not page.hidden %}
                {% set rootId = page.id|split('/')|first %}
                <li{% if page.id==current_page.id %} class="active" {% endif %}>
                    <a href="{{ page.url }}">
                        {% if navIcons[rootId] is defined %}
                        <i class="{{ navIcons[rootId] }}" aria-hidden="true"></i>
                        {% endif %}
                        {{ page.title }}
                    </a>
                </li>
                {% endfor %}
            </ul>
        </div>
    </div>
</div>